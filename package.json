{
  "name": "ledger",
  "version": "1.0.0",
  "description": "Ledger desktop app — a Litematica/Minecraft schematic material analyzer packaged with Electron.",
  "main": "main.js",
  "author": "intorez",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/iNotrez/litematica-ledger.git"
  },
  "scripts": {
    "start": "electron .",
    "sync:vendor": "node scripts/sync-vendor.js",
    "build:win": "electron-builder --win nsis --publish never",
    "release:win": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-log": "^5.4.1",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "jszip": "3.10.1",
    "pako": "2.1.0"
  },
  "build": {
    "appId": "com.intorez.ledger",
    "productName": "Ledger",
    "copyright": "Copyright © 2026 intorez",
    "asar": true,
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "package.json",
      "main.js",
      "preload.js",
      "index.html",
      "vendor/**/*",
      "build/**/*",
      "LICENSE",
      "README.md",
      "THIRD_PARTY_NOTICES.md"
    ],
    "publish": {
      "provider": "github",
      "owner": "iNotrez",
      "repo": "litematica-ledger",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "artifactName": "Ledger-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ledger",
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
